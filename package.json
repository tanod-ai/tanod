{
  "name": "tanod-ai",
  "version": "0.1.0-alpha.3",
  "description": "Open-source signed execution control for AI agents.",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run server",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "check": "npm run build && npm test && npm run test:openclaw-plugin",
    "server": "node dist/src/index.js server",
    "build:openclaw-plugin": "npm run build --prefix integrations/openclaw-plugin",
    "test:openclaw-plugin": "npm test --prefix integrations/openclaw-plugin"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
