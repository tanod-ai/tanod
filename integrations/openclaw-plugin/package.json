{
  "name": "@tanod/openclaw-plugin",
  "version": "0.1.0-alpha.0",
  "description": "OpenClaw plugin for Tanod signed execution control.",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
